# ─── App ──────────────────────────────────────────────────────────
# App base URL (used for OAuth redirect). For local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Backend API location (split deploy) ──────────────────────────
# On Vercel the Express API was bundled in-process and both of these
# were unset. On Coolify (and any split deploy) the API is a separate
# service, so point these at it:
#   API_ORIGIN     — next.config.mjs rewrites /api/v1/* to this origin.
#   INTERNAL_API_URL — server-side base URL for the GitHub OAuth
#                      exchange route's fetch to the API. Falls back to
#                      NEXT_PUBLIC_API_URL, then http://localhost:4000.
# Leave BOTH unset to keep the legacy in-process catch-all (Vercel mode).
# In Coolify use the api service's internal URL, e.g. http://api:4000.
# API_ORIGIN=http://localhost:4000
# INTERNAL_API_URL=http://localhost:4000


# ─── Authentication ───────────────────────────────────────────────
# When "true", the AuthGuard redirects unauthenticated visitors to
# /login. When "false" (default), the guard is a no-op — the existing
# localStorage flows keep working and the API integration is opt-in.
# Flip to "true" once the frontend mirror-mode work lands.
NEXT_PUBLIC_AUTH_REQUIRED=false


# ─── Jira ─────────────────────────────────────────────────────────
# Atlassian workspace URL (e.g. https://espace.atlassian.net).
# Per-user API tokens come from the UI.
NEXT_PUBLIC_JIRA_URL=


# ─── GitLab (self-hosted) ─────────────────────────────────────────
# GitLab instance URL (e.g. https://gitlab.espace.com.eg).
# GitLab uses Personal Access Tokens (pasted in Settings), no OAuth client.
NEXT_PUBLIC_GITLAB_URL=


# ─── GitHub ───────────────────────────────────────────────────────
# GitHub OAuth Application — register at github.com/settings/developers
# Redirect URL: {NEXT_PUBLIC_APP_URL}/oauth/github
NEXT_PUBLIC_GITHUB_CLIENT_ID=
# Server-side only — never expose
GITHUB_CLIENT_SECRET=


# ─── AI providers ─────────────────────────────────────────────────
# The dashboard's AI features (chat, goal classification, code-rubric
# grading) speak to one provider at a time. Both are OpenAI-compatible.
# Pick a default with AI_PROVIDER and configure the matching key. The
# Analyst page header has a pill switcher that lets you flip between
# them per session — that override sends `x-ai-provider` so the server
# uses whichever you've selected.
#
# Supported: "mistral" (default) | "glm" | "openrouter"
# AI_PROVIDER=mistral

# ── Mistral
# Create a key at console.mistral.ai. Server-side only — never expose.
MISTRAL_API_KEY=
# Optional model override. Defaults to `mistral-small-latest`.
# Other good options: mistral-medium-latest, mistral-large-latest.
# MISTRAL_MODEL=mistral-small-latest

# ── GLM (Z.ai)
# Create a key at z.ai. Server-side only — never expose.
GLM_API_KEY=
# Optional model override. Defaults to `glm-4.5-flash`. Other options:
# glm-4.5 (sharper reasoning), glm-4.5-air (cheaper).
# GLM_MODEL=glm-4.5-flash

# ── OpenRouter
# Single OpenAI-compatible gateway across many model hosts (Anthropic,
# Mistral, Qwen, DeepSeek, …). Create a key at openrouter.ai.
# Server-side only — never expose.
OPENROUTER_API_KEY=
# Optional model override. Defaults to `qwen/qwen3-next-80b-a3b-instruct:free`
# (free tier, fast). Pick any slug from openrouter.ai/models — e.g.
# `anthropic/claude-3.5-sonnet`, `deepseek/deepseek-chat`,
# `mistralai/mistral-large` — or append `:free` for free-tier variants.
# OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
