{
  "name": "@espace-devhub/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "eSpace Dev Hub — Express + MongoDB backend service.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json",
    "admin:create": "tsx scripts/admin-create.ts"
  },
  "dependencies": {
    "@espace-devhub/shared": "*",
    "@node-rs/argon2": "^2.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "mongodb": "^6.21.0",
    "nanoid": "^5.1.6",
    "otplib": "^12.0.1",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "resend": "^6.12.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.18.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
