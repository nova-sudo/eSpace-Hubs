# eSpace Dev Hub — API service environment.
#
# Copy this file to .env.local for development.
#
# In production these values come from a secret manager (Doppler /
# AWS Secrets Manager / equivalent), NOT a checked-in .env file.

# ─── runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of origins allowed to send credentialed requests.
# In dev, the Next frontend runs on :3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── mongo ───────────────────────────────────────────────────────────
# Local Mongo container is started by `docker compose up -d` from the
# repo root (see docker-compose.yml).
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=devhub-dev

# ─── session / crypto ────────────────────────────────────────────────
# Used to derive cookie signing keys. Set to a 32-byte random hex string
# in production. Rotate via key versioning (see plan §3.3).
# In dev a placeholder is fine.
SESSION_SECRET=dev-session-secret-change-me-in-prod-32bytes

# Master key for envelope-encrypting integration tokens at rest.
# 32-byte hex (64 chars) in production; KMS-managed.
INTEGRATION_TOKEN_KEY=dev-integration-master-key-change-in-prod-32b

# ─── ai providers ────────────────────────────────────────────────────
# Default provider when the request doesn't specify one.
# Options: anthropic | mistral | glm | openrouter
AI_PROVIDER=anthropic

# Per-provider keys + optional model overrides. Set whichever providers
# you actually use; the API surfaces a clear 500 with the missing
# env-var name when an unconfigured provider is requested.

# Claude (Anthropic) — native @anthropic-ai/sdk path (NOT OpenAI-compatible).
ANTHROPIC_API_KEY=
# Default model is claude-sonnet-4-6. Override here (e.g. claude-opus-4-8 for
# max intelligence, or claude-haiku-4-5 for lowest cost).
ANTHROPIC_MODEL=

MISTRAL_API_KEY=
MISTRAL_MODEL=

GLM_API_KEY=
GLM_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ─── app origin ──────────────────────────────────────────────────────
# Absolute origin used to build links in outbound emails (invite,
# password reset). Without this the invite link in a Gmail message
# would be a relative path and not clickable.
APP_URL=http://localhost:3000

# ─── email transport (Resend) ────────────────────────────────────────
# When RESEND_API_KEY is unset the email module logs the message
# instead of sending. Use that for fresh dev checkouts that don't
# have a Resend account yet.
#
# When set, Resend transport is enabled. Two domain modes:
#   sandbox  → sends from onboarding@resend.dev. Resend requires
#              recipients to be pre-verified in their dashboard;
#              perfect for dev. Branded as Resend, not eSpace.
#   verified → sends from RESEND_FROM_EMAIL on your verified domain.
#              Production path. Requires SPF/DKIM DNS records.
RESEND_API_KEY=
RESEND_DOMAIN_MODE=sandbox
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=eSpace Dev Hub

# ─── logging ─────────────────────────────────────────────────────────
LOG_LEVEL=debug
