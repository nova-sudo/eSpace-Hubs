# eSpace Dev Hub — API service environment.
#
# Copy this file to .env.local for development.
#
# In production these values come from a secret manager (Doppler /
# AWS Secrets Manager / equivalent), NOT a checked-in .env file.

# ─── runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of origins allowed to send credentialed requests.
# In dev, the Next frontend runs on :3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── mongo ───────────────────────────────────────────────────────────
# Local Mongo container is started by `docker compose up -d` from the
# repo root (see docker-compose.yml).
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=devhub-dev

# ─── session / crypto ────────────────────────────────────────────────
# Used to derive cookie signing keys. Set to a 32-byte random hex string
# in production. Rotate via key versioning (see plan §3.3).
# In dev a placeholder is fine.
SESSION_SECRET=dev-session-secret-change-me-in-prod-32bytes

# Master key for envelope-encrypting integration tokens at rest.
# 32-byte hex (64 chars) in production; KMS-managed.
INTEGRATION_TOKEN_KEY=dev-integration-master-key-change-in-prod-32b

# ─── ai providers ────────────────────────────────────────────────────
# Default provider when the request doesn't specify one.
# Options: mistral | glm | openrouter
AI_PROVIDER=mistral

# Per-provider keys + optional model overrides. Set whichever providers
# you actually use; the API surfaces a clear 500 with the missing
# env-var name when an unconfigured provider is requested.
MISTRAL_API_KEY=
MISTRAL_MODEL=

GLM_API_KEY=
GLM_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ─── logging ─────────────────────────────────────────────────────────
LOG_LEVEL=debug
