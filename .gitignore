# Dependencies — npm workspaces hoists most to root, but workspace-local
# node_modules can still appear during install resolution.
node_modules
**/node_modules

# Next build output (now lives under apps/web/, but match anywhere)
.next
**/.next

# TypeScript build output (apps/api/dist, future workspace dist dirs)
**/dist

# Env files — never commit
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# OS / editor
.DS_Store
Thumbs.db

# Logs
*.log

# Tooling caches
.turbo
**/.turbo
.tsbuildinfo
**/*.tsbuildinfo

# Next.js generates this on every dev/build/typecheck run — do not commit
apps/web/next-env.d.ts
