# Self-hosted GitLab base URL (e.g. https://gitlab.espace.com.eg)
NEXT_PUBLIC_GITLAB_URL=

# GitLab OAuth Application ID (registered on the self-hosted instance)
NEXT_PUBLIC_GITLAB_CLIENT_ID=

# GitHub OAuth Application Client ID
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# GitHub OAuth Application Client Secret (server-side only — never expose)
GITHUB_CLIENT_SECRET=

# Jira base URL (e.g. https://espace.atlassian.net). Per-user tokens come from the UI.
NEXT_PUBLIC_JIRA_URL=

# App base URL (used for OAuth redirect). For local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
